# Slack app tokens
# SLACK_BOT_TOKEN starts with xoxb-
# SLACK_APP_TOKEN starts with xapp- and needs connections:write
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-socket-mode-token

# Bot behavior
BOT_NAME=llm-bot
LOG_LEVEL=INFO
MAX_THREAD_MESSAGES=50
MAX_RESPONSE_TOKENS=1600

# Keep false if you only want the bot to respond when explicitly @mentioned.
RESPOND_TO_THREAD_FOLLOWUPS=false

# Enables DMing the bot a Slack thread link and getting a private summary.
ENABLE_DM_THREAD_LINK_SUMMARY=true

# OpenAI-compatible LLM API base URL.
# Examples:
#   http://litellm:4000/v1
#   http://vllm-host:8000/v1
#   http://host.docker.internal:4000/v1
LLM_BASE_URL=http://your-llm-api-host:4000/v1
LLM_API_KEY=sk-local
LLM_MODEL=your-model-name
LLM_TEMPERATURE=0.2
